NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/groweasy?retryWrites=true&w=majority

# --- AI providers ---
# Primary: DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Fallback: Gemini (https://aistudio.google.com/apikey) — used automatically
# whenever DeepSeek is unavailable or fails after retries.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

MAX_UPLOAD_SIZE_MB=10
AI_BATCH_SIZE=25
AI_CONCURRENCY=3
